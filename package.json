{
  "name": "cookie-clicker",
  "private": true,
  "type": "module",
  "imports": {
    "#lib/*": "./src/lib/*.ts"
  },
  "scripts": {
    "build": "vite build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "deploy": "bun run --sequential build wrangler:deploy",
    "dev": "vite dev",
    "format": "biome check --write",
    "knip": "knip && knip --production",
    "lint": "biome check",
    "prepare": "svelte-kit sync",
    "preview": "vite preview",
    "test": "bun test",
    "wrangler:deploy": "wrangler deploy"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "@gameroman/config": "0.2.5",
    "@sveltejs/adapter-static": "3.0.10",
    "@sveltejs/kit": "2.70.0",
    "@sveltejs/vite-plugin-svelte": "7.2.0",
    "@tailwindcss/vite": "4.3.3",
    "knip": "6.27.0",
    "svelte": "5.56.6",
    "svelte-check": "4.7.2",
    "tailwindcss": "4.3.3",
    "typescript": "6.0.3",
    "vite": "8.1.5",
    "wrangler": "4.110.0"
  }
}
